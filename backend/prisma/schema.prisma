// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  clerkId   String     @unique
  email     String?    @unique
  displayName String?
  age       Int?
  height    Float?     // in cm
  weight    Float?     // in kg
  bmi       Float?
  bloodPressure String?
  currentStatus String?
  jobStudyDescription String?
  likes     String?
  dislikes  String?
  relationshipStatus String?
  workingHours Float?
  sleepHours Float?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  moods         Mood[]
  healthMetrics HealthMetric[]
  activityEntries ActivityEntry[]
  gamification  Gamification?
  insights      Insight[]
  extensionTokens ExtensionToken[]
  browserEvents BrowserEvent[]
  pairingCodes  PairingCode[]

  @@index([clerkId])
  @@index([email])
}

model PairingCode {
  id          String   @id @default(cuid())
  code        String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceName  String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([code])
}

model ActivityEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  duration  Float?
  notes     String?
  intensity String?
  timestamp DateTime @default(now())
  date      String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, date])
  @@index([timestamp])
  @@index([type])
}

model ExtensionToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  deviceName String?
  createdAt DateTime @default(now())
  lastUsedAt DateTime?
  revokedAt DateTime?

  @@index([userId])
  @@index([tokenHash])
}

model BrowserEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  batchId   String?
  type      String
  source    String
  category  String?
  payload   Json?
  occurredAt DateTime
  createdAt DateTime @default(now())

  @@unique([userId, batchId])
  @@index([userId])
  @@index([occurredAt])
  @@index([type])
}

model Mood {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moodValue Int      // 1-5
  notes     String?
  timestamp DateTime @default(now())
  date      String   // YYYY-MM-DD

  @@index([userId])
  @@index([userId, date])
  @@index([timestamp])
}

model HealthMetric {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  metricType String   // sleep, exercise, water, meditation, notes
  value     Float
  unit      String?  // hours, minutes, liters, km, steps, etc.
  notes     String?
  timestamp DateTime @default(now())
  date      String   // YYYY-MM-DD

  @@index([userId])
  @@index([userId, date])
  @@index([userId, metricType])
}

model Gamification {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  xp        Int      @default(0)
  level     Int      @default(1)
  streak    Int      @default(0)
  lastActivityDate String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Insight {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String   // mood_pattern, health_recommendation, milestone, etc.
  title         String
  content       String
  embedding     String?  // Pinecone embedding ID
  createdAt     DateTime @default(now())
  isRead        Boolean  @default(false)

  @@index([userId])
  @@index([createdAt])
}
